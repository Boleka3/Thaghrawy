# ──────────────────────────────────────────────
# LLM Provider
# ──────────────────────────────────────────────
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (also used for any OpenAI-compatible endpoint, e.g. LM Studio, Ollama,
# OpenRouter, llama.cpp) via OPENAI_BASE_URL.
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o
#
# OPENAI_BASE_URL — where the LLM lives. Pick the line matching your deployment:
#   • Cloud API (OpenAI): leave empty. Works out of the box (container has internet egress).
#   • Cloud-compatible (e.g. OpenRouter): https://openrouter.ai/api/v1
#   • Local LLM on THIS machine, running in Docker: http://host.docker.internal:1234/v1
#     (LM Studio :1234). Bind the LLM server to 0.0.0.0, not 127.0.0.1, so the container
#     can reach it. Running the app WITHOUT Docker instead? use http://localhost:1234/v1
#   • Local LLM on ANOTHER LAN machine: http://<lan-ip>:1234/v1 (that server must bind its
#     LAN interface and the firewall must allow the port).
#   • LLM as a sibling docker-compose service: http://<service-name>:<port>/v1
OPENAI_BASE_URL=

# Ollama. In Docker use host.docker.internal (see notes above); bare-metal use localhost.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Max assistant<->tool round-trips per user turn (agent ReAct loop). Raise for
# deeper multi-subdomain recon; lower to cap cost/runaway loops.
MAX_TOOL_ITERATIONS=20

# ──────────────────────────────────────────────
# ChromaDB / memory layer
# ──────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
# Point at the local snapshot dir to avoid re-downloading the embedding
# model (see README for where this cache lives).
EMBEDDING_MODEL_PATH=sentence-transformers/all-MiniLM-L6-v2

# ──────────────────────────────────────────────
# Engagements / workspace
# ──────────────────────────────────────────────
ENGAGEMENTS_DIR=./engagements/sessions
WORKSPACE_DIR=./engagements/sessions/_workspace
REPORTS_DIR=./reports

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ──────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────
MAX_SHELL_TIMEOUT=30
RECON_TIMEOUT=180
DANGEROUS_COMMANDS_REQUIRE_CONFIRM=true
